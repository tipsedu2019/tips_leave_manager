rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null &&
        !exists(/databases/$(database)/documents/blockedUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPrivileged() {
      return isAuthenticated() &&
        (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'MANAGER']
          ) ||
          (
            request.auth.token.email == "yeoyuasset@gmail.com" &&
            request.auth.token.email_verified == true
          )
        );
    }

    function isValidUser(data) {
      return data.keys().hasOnly([
               'uid',
               'email',
               'displayName',
               'role',
               'totalLeave',
               'usedLeave',
               'totalCompLeave',
               'usedCompLeave',
               'joinDate',
               'carryoverLeaves',
               'nextLeaveAccrualDate'
             ]) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['ADMIN', 'MANAGER', 'EMPLOYEE'] &&
             data.totalLeave is number &&
             data.usedLeave is number &&
             data.totalCompLeave is number &&
             data.usedCompLeave is number &&
             data.joinDate is string &&
             data.carryoverLeaves is list &&
             data.nextLeaveAccrualDate is string;
    }

    function isValidLeaveRequest(data) {
      return data.keys().hasAll([
               'id',
               'userId',
               'userName',
               'type',
               'startDate',
               'endDate',
               'status',
               'createdAt',
               'daysCount'
             ]) &&
             data.keys().hasOnly([
               'id',
               'userId',
               'userName',
               'type',
               'startDate',
               'endDate',
               'status',
               'createdAt',
               'daysCount',
               'adminComment',
               'approvalAdjustment'
             ]) &&
             data.id is string &&
             data.userId is string &&
             data.userName is string &&
             data.startDate is string &&
             data.endDate is string &&
             data.createdAt is string &&
             data.type in ['ANNUAL', 'HALF_DAY', 'SICK', 'SPECIAL', 'COMPENSATORY', 'OTHER'] &&
             data.status == 'PENDING' &&
             data.daysCount is number;
    }

    function isValidLeaveReason(data) {
      return data.keys().hasOnly(['requestId', 'userId', 'reason', 'createdAt']) &&
             data.requestId is string &&
             data.userId is string &&
             data.reason is string &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll([
               'userId',
               'actorId',
               'title',
               'message',
               'createdAt'
             ]) &&
             data.keys().hasOnly([
               'userId',
               'actorId',
               'title',
               'message',
               'createdAt',
               'readAt',
               'linkTab'
             ]) &&
             data.userId is string &&
             data.actorId is string &&
             data.title is string &&
             data.message is string &&
             data.createdAt is string &&
             (!data.keys().hasAny(['readAt']) || data.readAt is string) &&
             (!data.keys().hasAny(['linkTab']) || data.linkTab in ['dashboard', 'history', 'admin']);
    }

    function isValidCompLeaveGrant(data) {
      return data.keys().hasOnly([
               'id',
               'userId',
               'amount',
               'workDate',
               'grantedAt',
               'grantedBy',
               'grantedByName'
             ]) &&
             data.id is string &&
             data.userId is string &&
             data.amount is number &&
             data.workDate is string &&
             data.grantedAt is string &&
             data.grantedBy is string &&
             data.grantedByName is string;
    }

    function requestIsPending(requestId) {
      return exists(/databases/$(database)/documents/leaveRequests/$(requestId)) &&
        get(/databases/$(database)/documents/leaveRequests/$(requestId)).data.status == 'PENDING';
    }

    function ownerCanEditPendingRequest() {
      return isOwner(resource.data.userId) &&
        resource.data.status == 'PENDING' &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.id == resource.data.id &&
        isValidLeaveRequest(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isPrivileged() && isValidUser(request.resource.data)) ||
        (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
      allow delete: if isPrivileged();
    }

    match /leaveRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == requestId &&
        isValidLeaveRequest(request.resource.data);
      allow update: if isPrivileged() || ownerCanEditPendingRequest();
      allow delete: if isPrivileged() || (isOwner(resource.data.userId) && resource.data.status == 'PENDING');
    }

    match /leaveRequestReasons/{requestId} {
      allow read: if isPrivileged() || (
        isOwner(resource.data.userId) &&
        requestIsPending(resource.data.requestId)
      );
      allow create: if (
        isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.requestId == requestId &&
        isValidLeaveReason(request.resource.data)
      ) || (
        isPrivileged() &&
        isValidLeaveReason(request.resource.data)
      );
      allow update: if isPrivileged() || (
        isOwner(resource.data.userId) &&
        requestIsPending(resource.data.requestId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.requestId == resource.data.requestId &&
        isValidLeaveReason(request.resource.data)
      );
      allow delete: if isPrivileged() || (
        isOwner(resource.data.userId) &&
        requestIsPending(resource.data.requestId)
      );
    }

    match /adminLogs/{logId} {
      allow read: if isPrivileged();
      allow create: if isPrivileged();
    }

    match /blockedUsers/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId) || isPrivileged();
      allow list: if isPrivileged();
      allow create, delete: if isPrivileged();
    }

    match /compLeaveGrants/{grantId} {
      allow read: if isPrivileged() || isOwner(resource.data.userId);
      allow create: if isPrivileged() &&
        request.resource.data.id == grantId &&
        isValidCompLeaveGrant(request.resource.data);
      allow delete: if isPrivileged();
    }

    match /notifications/{notificationId} {
      allow get: if isPrivileged() || isOwner(resource.data.userId);
      allow list: if isPrivileged();
      allow create: if isAuthenticated() &&
        request.resource.data.actorId == request.auth.uid &&
        isValidNotification(request.resource.data);
      allow update: if isOwner(resource.data.userId) &&
        isValidNotification(request.resource.data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt']);
      allow delete: if isPrivileged();
    }
  }
}
